{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "servertype": "openocd",
            "device": "STM32F103C8",
            "svdFile": "${workspaceFolder}/STM32F103.svd",
            "executable": "${workspaceFolder}/build/Debug/9-7_FreeRTOS_Questnotice.elf",
            "gdbPath": "arm-none-eabi-gdb",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f1x.cfg"
            ],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "gdbTargetOptions": [
                "set breakpoint auto-hw on",
                "set print pretty on",
                "set pagination off",
                "set history save on"
            ]
        }
    ]
}